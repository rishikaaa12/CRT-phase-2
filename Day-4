# problem - 1
# leetcode problem 
# 3612 - process string with special operations

class Solution {
public:
    string processStr(string s) {
        string res;
        int n = s.length();

        for (int i = 0; i < n; i++) {
            char ch = s[i];

            if (ch == '*') {
                if (res.length() != 0) {
                    res.pop_back();
                }
            } 
            else if (ch == '#') {
                res += res;
            } 
            else if (ch == '%') {
                reverse(res.begin(), res.end());
            } 
            else if (ch >= 'a' && ch <= 'z') {
                res.push_back(ch);
            }
        }

        return res;
    }
};

# problem -2 
# binary search algorithm 

#include <iostream>
using namespace std;
#include <vector>

int binarySearch(vector<int> &arr, int target) {
    int low = 0;
    int high = arr.size() - 1;
    
    while(low <= high) {
        int mid = low + (high - low) / 2;
        
        if(arr[mid] == target) {
            return mid;
        }
        if(arr[mid] < target) {
            low = mid + 1;
        } else {
            high = mid - 1;
        }
    }
    return -1;
}
