# problem - 3 
# geeks for geeks problem
# ceil in a sorted array 
class Solution {
  public:
    int findCeil(vector<int>& arr, int x) {
        
        int low = 0;
        int high = arr.size() - 1;
        int ans = -1;
        
        while(low <= high) {
            int mid = low + high - low / 2;
            
            if(arr[mid] >= x) {
                ans = mid;
                high = mid -1;
            } else {
                low = mid + 1;
            }
            }
            return ans;
    }
};
